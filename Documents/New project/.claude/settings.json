{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm install)",
      "Bash(npm.cmd install)",
      "Bash(npm run *)",
      "Bash(npm.cmd run *)",
      "Bash(npm --workspace * run *)",
      "Bash(npm.cmd --workspace * run *)",
      "Bash(npx tsc *)",
      "Bash(npx tsx *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git branch)",
      "Bash(git branch *)",
      "Bash(git fetch)",
      "Bash(git fetch *)",
      "Bash(git pull)",
      "Bash(git pull *)",
      "Bash(git add *)",
      "Bash(git restore --staged *)",
      "Bash(git stash *)",
      "Bash(curl -s http://127.0.0.1:* *)",
      "Bash(curl -s http://localhost:* *)",
      "Bash(curl -o NUL *)",
      "Bash(ls *)",
      "Bash(cat *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -rf /*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(npm publish*)",
      "Bash(npm.cmd publish*)",
      "Bash(* > server/server/data/store.json*)",
      "Bash(* >> server/server/data/store.json*)"
    ]
  }
}
